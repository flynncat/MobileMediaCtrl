<Window x:Class="MediaBrowser.App.Views.MediaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"

        Title="{Binding Title}"
        Width="1100"
        Height="780"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDrop="Window_PreviewDrop">


  <DockPanel Margin="12">
    <Border DockPanel.Dock="Top" Padding="0,0,0,12">
      <StackPanel>
        <TextBlock Text="{Binding StatusText}" Margin="0,0,0,8"
                   AutomationProperties.Name="状态说明"/>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="{DynamicResource Media_CopyToFolder}" VerticalAlignment="Center" Margin="0,0,8,0"/>

          <TextBox Grid.Column="1"
                   Text="{Binding CurrentDropTargetPath, UpdateSourceTrigger=PropertyChanged}"
                   AutomationProperties.Name="复制目标路径"/>
          <Button Grid.Column="2" Content="{DynamicResource Media_Browse}" Command="{Binding BrowseTargetFolderCommand}"
                  AutomationProperties.Name="浏览目标文件夹"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
          <Button Content="{DynamicResource Media_Refresh}" Command="{Binding RefreshCommand}" AutomationProperties.Name="刷新列表"/>
          <Button Content="{DynamicResource Media_CopySelected}" Command="{Binding CopySelectedToTargetCommand}"
                  AutomationProperties.Name="复制已选到目标文件夹"/>
          <Button Content="{DynamicResource Media_ToggleSelectAll}" Command="{Binding ToggleSelectAllCommand}"
                  AutomationProperties.Name="全选或取消全选"/>
          <Button Content="{DynamicResource Media_OpenExportFolder}" Command="{Binding OpenExportFolderCommand}"
                  AutomationProperties.Name="打开导出文件夹"/>

        </StackPanel>

        <TextBlock Text="{DynamicResource Media_Hint}"
                   FontSize="16"
                   Opacity="0.65"
                   Margin="0,8,0,0"/>

      </StackPanel>
    </Border>

    <!-- 使用 Grid 叠加 Sticky Header 覆盖层 -->
    <Grid>
      <!-- 主列表：嵌套 ItemsControl（年→月→媒体项） -->
      <ScrollViewer x:Name="MainScrollViewer"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    CanContentScroll="False"
                    ScrollChanged="MainScrollViewer_ScrollChanged">
        <ItemsControl x:Name="YearItemsControl"
                      ItemsSource="{Binding YearGroups}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel>
                <!-- 年份标题行 -->
                <Border Background="#E8E8E8" Padding="8,6" Margin="0,8,0,0" CornerRadius="4"
                        Cursor="Hand" MouseLeftButtonDown="YearHeader_MouseLeftButtonDown"
                        Tag="YearHeader">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding DisplayLabel}"
                               FontSize="20" FontWeight="Bold" Foreground="#222"/>
                    <TextBlock FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"
                               Foreground="#666">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text" Value="▼"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                              <Setter Property="Text" Value="▶"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>

                  </StackPanel>
                </Border>

                <!-- 月份列表（年份展开时可见） -->
                <ItemsControl ItemsSource="{Binding MonthGroups}">
                  <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                      <Setter Property="Visibility" Value="Visible"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                          <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </ItemsControl.Style>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel>
                        <!-- 月份标题行 -->
                        <Border Background="#F2F2F2" Padding="12,4" Margin="0,4,0,0" CornerRadius="3"
                                Cursor="Hand" MouseLeftButtonDown="MonthHeader_MouseLeftButtonDown"
                                Tag="MonthHeader">
                          <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayLabel}"
                                       FontSize="16" FontWeight="SemiBold" Foreground="#444"/>
                            <TextBlock FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"
                                       Foreground="#888">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Text" Value="▼"/>
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                      <Setter Property="Text" Value="▶"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>

                          </StackPanel>
                        </Border>

                        <!-- 媒体项网格（月份展开时可见） -->
                        <ItemsControl ItemsSource="{Binding Items}">
                          <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                              <Setter Property="Visibility" Value="Visible"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                  <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </ItemsControl.Style>
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Width="160" Height="200" Margin="6" BorderBrush="#CCC" BorderThickness="1"
                                      CornerRadius="4" Background="White"
                                      PreviewMouseLeftButtonDown="Tile_PreviewMouseLeftButtonDown"
                                      PreviewMouseMove="Tile_PreviewMouseMove"
                                      PreviewMouseLeftButtonUp="Tile_PreviewMouseLeftButtonUp"
                                      MouseLeftButtonDown="Tile_MouseDoubleClick"
                                      AutomationProperties.Name="媒体缩略图卡片">

                                <DockPanel>
                                  <CheckBox DockPanel.Dock="Top"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Content="{DynamicResource Media_Select}"
                                            Margin="4"
                                            AutomationProperties.Name="选择此文件"/>
                                  <!-- 缩略图 + 视频播放图标叠加 -->
                                  <Grid Height="120" Margin="4">
                                    <!-- 缩略图 -->
                                    <Image Stretch="UniformToFill"
                                           Source="{Binding Thumbnail}"
                                           AutomationProperties.Name="{Binding Item.DisplayName}"/>
                                    <!-- 视频默认占位图标（当缩略图为空且是视频时显示） -->
                                    <Border Background="#88000000" CornerRadius="4"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Padding="12">
                                      <Border.Style>
                                        <Style TargetType="Border">
                                          <Setter Property="Visibility" Value="Collapsed"/>
                                          <Style.Triggers>
                                            <MultiDataTrigger>
                                              <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsVideo}" Value="True"/>
                                                <Condition Binding="{Binding Thumbnail}" Value="{x:Null}"/>
                                              </MultiDataTrigger.Conditions>
                                              <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </Border.Style>
                                      <TextBlock Text="🎬" FontSize="28" Foreground="White"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- 视频播放图标叠加（当是视频且有缩略图时显示） -->
                                    <Border Background="#66000000" CornerRadius="20"
                                            Width="40" Height="40"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                      <Border.Style>
                                        <Style TargetType="Border">
                                          <Setter Property="Visibility" Value="Collapsed"/>
                                          <Style.Triggers>
                                            <MultiDataTrigger>
                                              <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsVideo}" Value="True"/>
                                              </MultiDataTrigger.Conditions>
                                              <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                              <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsVideo}" Value="True"/>
                                                <Condition Binding="{Binding Thumbnail}" Value="{x:Null}"/>
                                              </MultiDataTrigger.Conditions>
                                              <Setter Property="Visibility" Value="Collapsed"/>
                                            </MultiDataTrigger>
                                          </Style.Triggers>
                                        </Style>
                                      </Border.Style>
                                      <Path Data="M8,0 L20,10 L8,20 Z" Fill="White"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Margin="3,0,0,0"/>
                                    </Border>
                                  </Grid>
                                  <TextBlock Text="{Binding Item.DisplayName}" TextTrimming="CharacterEllipsis"
                                             Margin="4,0,4,4" FontSize="14" MaxHeight="44"/>
                                </DockPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Sticky Header 覆盖层 -->
      <Border x:Name="StickyHeaderBorder"
              VerticalAlignment="Top" HorizontalAlignment="Stretch"
              Background="#F0F0F0" Padding="8,4" CornerRadius="0,0,4,4"
              Visibility="Collapsed"
              IsHitTestVisible="False">
        <StackPanel Orientation="Horizontal">
          <TextBlock x:Name="StickyYearText" FontSize="18" FontWeight="Bold" Foreground="#222"/>
          <TextBlock Text=" · " FontSize="16" Foreground="#666" Margin="4,0"/>
          <TextBlock x:Name="StickyMonthText" FontSize="16" FontWeight="SemiBold" Foreground="#444"/>
        </StackPanel>
      </Border>
    </Grid>

  </DockPanel>
</Window>
