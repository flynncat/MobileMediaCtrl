<Window x:Class="MediaBrowser.App.Views.MediaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1100"
        Height="780"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDrop="Window_PreviewDrop">
  <DockPanel Margin="12">
    <Border DockPanel.Dock="Top" Padding="0,0,0,12">
      <StackPanel>
        <TextBlock Text="{Binding StatusText}" Margin="0,0,0,8"
                   AutomationProperties.Name="状态说明"/>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="复制到文件夹：" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBox Grid.Column="1"
                   Text="{Binding CurrentDropTargetPath, UpdateSourceTrigger=PropertyChanged}"
                   AutomationProperties.Name="复制目标路径"/>
          <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseTargetFolderCommand}"
                  AutomationProperties.Name="浏览目标文件夹"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
          <Button Content="刷新列表" Command="{Binding RefreshCommand}" AutomationProperties.Name="刷新列表"/>
          <Button Content="复制已选到目标文件夹" Command="{Binding CopySelectedToTargetCommand}"
                  AutomationProperties.Name="复制已选到目标文件夹"/>
          <Button Content="全选/取消全选" Command="{Binding ToggleSelectAllCommand}"
                  AutomationProperties.Name="全选或取消全选"/>
        </StackPanel>
        <TextBlock Text="提示：勾选后可拖到桌面/文件夹；双击可预览。"
                   FontSize="13"
                   Opacity="0.65"
                   Margin="0,8,0,0"/>

      </StackPanel>
    </Border>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <ItemsControl ItemsSource="{Binding DayGroups}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Expander IsExpanded="True" Header="{Binding DateLabel}">
              <ItemsControl ItemsSource="{Binding Items}" Margin="0,8,0,0">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Width="160" Height="200" Margin="6" BorderBrush="#CCC" BorderThickness="1"
                            CornerRadius="4"
                            PreviewMouseLeftButtonDown="Tile_PreviewMouseLeftButtonDown"
                            PreviewMouseMove="Tile_PreviewMouseMove"
                            PreviewMouseLeftButtonUp="Tile_PreviewMouseLeftButtonUp"
                            MouseLeftButtonDown="Tile_MouseDoubleClick"
                            AutomationProperties.Name="媒体缩略图卡片">

                      <DockPanel>
                        <CheckBox DockPanel.Dock="Top"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Content="选择"
                                  Margin="4"
                                  AutomationProperties.Name="选择此文件"/>
                        <Image Height="120" Stretch="UniformToFill" Margin="4"
                               Source="{Binding Thumbnail}"
                               AutomationProperties.Name="{Binding Item.DisplayName}"/>
                        <TextBlock Text="{Binding Item.DisplayName}" TextTrimming="CharacterEllipsis"
                                   Margin="4,0,4,4" FontSize="14" MaxHeight="44"/>
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Expander>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</Window>
