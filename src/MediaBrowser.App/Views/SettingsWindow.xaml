<Window x:Class="MediaBrowser.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings_Title}"
        Width="420"
        Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
  <StackPanel Margin="24" VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
      <TextBlock Text="{DynamicResource Settings_Language}" VerticalAlignment="Center" Margin="0,0,12,0"/>
      <ComboBox x:Name="LanguageCombo" Width="200" MinHeight="36"/>
    </StackPanel>
    <CheckBox x:Name="AutoStartCheckBox"
              Content="{DynamicResource Settings_AutoStart}"
              Margin="0,0,0,16"
              VerticalAlignment="Center"/>
    <TextBlock Text="{DynamicResource Settings_RestartHint}"
               Opacity="0.65" FontSize="13" Margin="0,0,0,16"/>
    <Button Content="{DynamicResource Settings_Save}" Click="Save_Click"
            HorizontalAlignment="Left" MinWidth="80"/>
  </StackPanel>
</Window>
