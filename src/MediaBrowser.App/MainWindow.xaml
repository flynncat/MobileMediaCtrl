        Title="外接盘媒体浏览"
        Width="720"
        Height="420"
        WindowStartupLocation="CenterScreen">
  <StackPanel Margin="24" VerticalAlignment="Center">
    <TextBlock Text="程序已在运行。" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>
