<Window x:Class="MediaBrowser.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource MainWindow_Title}"
        Width="720"
        Height="420"
        WindowStartupLocation="CenterScreen">
  <StackPanel Margin="24" VerticalAlignment="Center">
    <TextBlock Text="{DynamicResource MainWindow_Running}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>
    <TextBlock Text="{DynamicResource MainWindow_Hint1}"
               Margin="0,0,0,12"/>
    <TextBlock Text="{DynamicResource MainWindow_Hint2}"
               Opacity="0.85"
               Margin="0,0,0,16"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
      <Button Content="{DynamicResource MainWindow_Settings}" Click="Settings_Click"
              MinWidth="80" Margin="0,0,12,0"/>
      <Button x:Name="ReopenButton"
              Content="{DynamicResource MainWindow_Reopen}" Click="Reopen_Click"
              MinWidth="120"/>
    </StackPanel>
  </StackPanel>
</Window>

