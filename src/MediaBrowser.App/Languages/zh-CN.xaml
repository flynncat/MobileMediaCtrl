<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
  <!-- MainWindow -->
  <sys:String x:Key="MainWindow_Title">外接媒体浏览器</sys:String>
  <sys:String x:Key="MainWindow_Running">应用程序运行中。</sys:String>
  <sys:String x:Key="MainWindow_Hint1">插入 U 盘或连接手机并选择"文件传输"模式，将自动弹出浏览窗口。</sys:String>
  <sys:String x:Key="MainWindow_Hint2">可以最小化此窗口，不影响自动弹出功能。</sys:String>
  <sys:String x:Key="MainWindow_Settings">设置</sys:String>

  <!-- MediaWindow -->
  <sys:String x:Key="Media_CopyToFolder">复制到文件夹：</sys:String>
  <sys:String x:Key="Media_Browse">浏览...</sys:String>
  <sys:String x:Key="Media_Refresh">刷新列表</sys:String>
  <sys:String x:Key="Media_CopySelected">复制已选到目标文件夹</sys:String>
  <sys:String x:Key="Media_ToggleSelectAll">全选/取消全选</sys:String>
  <sys:String x:Key="Media_OpenExportFolder">打开导出文件夹</sys:String>
  <sys:String x:Key="Media_Hint">提示：勾选文件后可拖拽到桌面/文件夹；双击可预览。</sys:String>

  <sys:String x:Key="Media_Select">选择</sys:String>

  <!-- PreviewWindow -->
  <sys:String x:Key="Preview_Title">预览</sys:String>
  <sys:String x:Key="Preview_Loading">正在加载预览...</sys:String>
  <sys:String x:Key="Preview_PlayPause">暂停/播放</sys:String>
  <sys:String x:Key="Preview_Close">关闭</sys:String>
  <sys:String x:Key="Preview_CannotPreview">无法预览此文件。</sys:String>
  <sys:String x:Key="Preview_Failed">预览失败：{0}</sys:String>

  <!-- SettingsWindow -->
  <sys:String x:Key="Settings_Title">设置</sys:String>
  <sys:String x:Key="Settings_Language">语言：</sys:String>
  <sys:String x:Key="Settings_Save">保存</sys:String>
  <sys:String x:Key="Settings_RestartHint">切换语言后部分内容需重启应用才能完全生效。</sys:String>
  <sys:String x:Key="Settings_AutoStart">开机时自动启动</sys:String>
  <sys:String x:Key="Settings_AutoStartFailed">设置开机自启动失败，请检查权限。</sys:String>

  <!-- FirstRun Dialog -->
  <sys:String x:Key="FirstRun_Title">欢迎使用</sys:String>
  <sys:String x:Key="FirstRun_Message">是否在 Windows 开机时自动启动 MediaBrowser？&#x0a;&#x0a;您随时可以在"设置"中修改此选项。</sys:String>
  <sys:String x:Key="FirstRun_Yes">是</sys:String>
  <sys:String x:Key="FirstRun_No">否</sys:String>


  <!-- ViewModel / Code-behind 使用的字符串 -->
  <sys:String x:Key="VM_Loading">正在加载...</sys:String>
  <sys:String x:Key="VM_DeviceNotFound">未找到手机/便携设备，请重新连接。</sys:String>
  <sys:String x:Key="VM_MediaCount">共 {0} 个媒体文件。路径栏即为复制目标。</sys:String>
  <sys:String x:Key="VM_LoadFailed">加载失败：{0}</sys:String>
  <sys:String x:Key="VM_BrowseFolder">选择复制目标文件夹</sys:String>
  <sys:String x:Key="VM_PleaseSelect">请先勾选要复制的文件。</sys:String>
  <sys:String x:Key="VM_Hint">提示</sys:String>
  <sys:String x:Key="VM_CopyResult">复制结果</sys:String>
  <sys:String x:Key="VM_CopyDone">完成：成功 {0}，跳过 {1}，失败 {2}。</sys:String>
  <sys:String x:Key="VM_CopiedToTarget">已复制到目标文件夹：&#x0a;{0}&#x0a;成功 {1}，跳过 {2}，失败 {3}。</sys:String>
  <sys:String x:Key="VM_ExternalDropDone">外部文件已复制到目标文件夹。</sys:String>
  <sys:String x:Key="VM_ExternalDropDoneDetailed">外部文件已复制到设备：&#x0a;{0}&#x0a;成功 {1}，跳过 {2}，失败 {3}。</sys:String>
  <sys:String x:Key="VM_ExternalDropMtpUnsupported">当前设备为手机（MTP），暂不支持向手机写入文件。如需复制到手机，请使用电脑文件夹中的复制操作。</sys:String>
  <sys:String x:Key="VM_ExternalDropNoTarget">未找到当前设备的目标路径，无法复制。</sys:String>

  <sys:String x:Key="VM_Done">完成</sys:String>
  <sys:String x:Key="VM_ExportFolderNotExist">导出文件夹不存在，请先设置有效的目标路径。</sys:String>
  <sys:String x:Key="VM_OpenFolderFailed">打开文件夹失败：{0}</sys:String>
  <sys:String x:Key="VM_PreparingDrag">正在准备文件，请稍候...</sys:String>


  <!-- MTP 扫描 -->
  <sys:String x:Key="Mtp_FoundVolumes">发现 {0} 个存储卷，正在扫描</sys:String>
  <sys:String x:Key="Mtp_Scanning">正在扫描 {0}……已发现 {1} 个文件</sys:String>
  <sys:String x:Key="Mtp_ScanDone">扫描完成，共 {0} 个媒体文件。</sys:String>
  <sys:String x:Key="Mtp_FoundFiles">已发现 {0} 个媒体文件...</sys:String>

  <!-- 月分组 -->
  <sys:String x:Key="Group_MonthFormat">{0}年{1}月</sys:String>
  <sys:String x:Key="Group_YearFormat">{0}年</sys:String>
  <sys:String x:Key="Group_ItemCount">{0} 项</sys:String>


  <!-- 增量扫描 -->
  <sys:String x:Key="VM_Scanning">正在扫描…已找到 {0} 个文件</sys:String>

  <!-- DeviceArrival -->
  <sys:String x:Key="Device_UsbDrive">U 盘 ({0})</sys:String>
</ResourceDictionary>
